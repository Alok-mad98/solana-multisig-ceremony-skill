# Solana Multisig Ceremony & Build Integrity Skill — environment variables
# Copy this file to .env and fill in your own values. Never commit .env.

# Solana RPC endpoint
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional: Helius API key for enhanced RPC / DAS API
HELIUS_API_KEY=

# Optional: default multisig address to audit (Squads v4 or SPL Governance)
SQUADS_MULTISIG_ADDRESS=

# Optional: path to a read-only wallet used for RPC-authorized calls (never a hot signer)
ANCHOR_PROVIDER_WALLET=
